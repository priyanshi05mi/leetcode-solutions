import java.util.*;

class Solution {
    List<List<Integer>> res;
    int target;

    public List<List<Integer>> combinationSum(int[] candidates, int target) {
        res = new ArrayList<>();
        this.target = target;
        check(candidates, 0, 0, new ArrayList<>());
        return res;
    }

    void check(int[] nums, int i, int sum, ArrayList<Integer> arr) {
        if (i == nums.length) {
            if (sum == target) {
                res.add(new ArrayList<>(arr));
            }
            return;
        }

        // Take current element
        if (sum + nums[i] <= target) {
            arr.add(nums[i]);
            check(nums, i, sum + nums[i], arr);  // reuse same element
            arr.remove(arr.size() - 1);
        }

        // Skip current element
        check(nums, i + 1, sum, arr);
    }
}
